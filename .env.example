# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres direct (Drizzle uses this; Supabase pooler or direct connection)
DATABASE_URL=postgresql://postgres:password@db.host.supabase.co:5432/postgres

# Webhook Respondi.app (paste this token in the webhook URL query string at Respondi panel)
WEBHOOK_TOKEN_RESPONDI=generate-a-long-random-string

# Direcionador / link-na-bio (POST /api/public/bio-lead — vindo do site da Giulia)
# Origens permitidas (CORS + checagem de Origin/Referer), separadas por vírgula.
BIO_LEAD_ALLOWED_ORIGINS=https://giuliasalvatore.com,http://localhost:5173
# Token compartilhado (camada extra; o MESMO valor vai em VITE_AOS_LEAD_TOKEN no site).
# NÃO é segredo real (vai no bundle do client) — a defesa real é honeypot + rate-limit.
BIO_LEAD_TOKEN=generate-a-long-random-string
# Slug do stage de entrada do bio-quiz (default frio, separado do funil principal).
BIO_LEAD_STAGE_SLUG=bio_quiz_novo

# Cron auth (Vercel adds this header automatically when configured)
CRON_SECRET=generate-a-long-random-string

# OpenAI (motor de análise comercial CallScore — closer/SDR, GPT-4o)
OPENAI_API_KEY=sk-your-openai-key

# Evolution API (WhatsApp — pull sob demanda para análise SDR)
EVOLUTION_API_URL=https://your-evolution-host        # base URL, sem barra no final
EVOLUTION_API_KEY=your-evolution-apikey
EVOLUTION_INSTANCE=your-instance-name                # nome da instância conectada

# Google Calendar (agenda da Renata — OAuth, mão única CRM→Google)
# Cloud Console: OAuth client "Web application", consent screen External + In production
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/google/oauth/callback

# Meta Ads (pipeline de análise de criativos — sync read-only de insights)
META_ACCESS_TOKEN=your-meta-system-user-token       # token de System User do Business Manager (não expira; token de usuário morre em 60d)
META_AD_ACCOUNT_ID=1234567890                       # somente números, SEM prefixo act_ (o código prepende)

# App URL (used for Supabase invite redirects)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Operation
NEXT_PUBLIC_OPERATION_TZ=America/Sao_Paulo
