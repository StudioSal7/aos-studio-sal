# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres direct (Drizzle uses this; Supabase pooler or direct connection)
DATABASE_URL=postgresql://postgres:password@db.host.supabase.co:5432/postgres

# Webhook Respondi.app (paste this token in the webhook URL query string at Respondi panel)
WEBHOOK_TOKEN_RESPONDI=generate-a-long-random-string

# Cron auth (Vercel adds this header automatically when configured)
CRON_SECRET=generate-a-long-random-string

# App URL (used for Supabase invite redirects)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Operation
NEXT_PUBLIC_OPERATION_TZ=America/Sao_Paulo
